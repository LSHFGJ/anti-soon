			},
			"evidenceDir": ".sisyphus/evidence/live-verify",
			"wsRpcUrlEnvVar": "CRE_SIM_WS_RPC_URL",
			"contractAddress": "0x3fbd5ab0f3fd234a40923ae7986f45acb9d4a3cf",
			"topic0": "0xc3c91f25332a5a28defde601c6ccdf9ba0eeb99c94ef7a6cc5fb5a7e7737643f"
