CRE_ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://eth.llamarpc.com
TENDERLY_API_KEY_VALUE=your-tenderly-api-key
LLM_API_KEY_VALUE=your-openrouter-api-key
BLOCKCHAIR_API_KEY_VALUE=your-blockchair-api-key
# Frontend API base URL (backend handles Storacha uploads)
VITE_API_URL=http://localhost:3000

# Backend/workflow metadata upload auth token (for /api/metadata/upload)
METADATA_UPLOAD_TOKEN_VALUE=your-metadata-upload-token

# Optional: queue reveal signatures in MULTI mode and execute via relayer
VITE_ENABLE_AUTO_REVEAL_QUEUE=false
AUTO_REVEAL_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
AUTO_REVEAL_PRIVATE_KEY=0xyour_relayer_private_key
AUTO_REVEAL_BOUNTY_HUB_ADDRESS=0x8b12D6F28453be1eEf2D5ff151df3a2eE68d7f97
AUTO_REVEAL_CHAIN_ID=11155111
AUTO_REVEAL_LOOKBACK_BLOCKS=5000
AUTO_REVEAL_REPLAY_OVERLAP_BLOCKS=12
AUTO_REVEAL_LOG_CHUNK_BLOCKS=5000
# Optional persistent cursor path for relayer restarts
AUTO_REVEAL_CURSOR_FILE=workflow/auto-reveal-relayer/.auto-reveal-cursor.json
