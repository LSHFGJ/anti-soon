TENDERLY_API_KEY_VALUE=your-tenderly-api-key
LLM_API_KEY_VALUE=your-openrouter-api-key

# Frontend API base URL (backend handles Storacha uploads)
VITE_API_URL=http://localhost:3000
VITE_ENABLE_DOCS=true
VITE_ENABLE_AUTO_REVEAL_QUEUE=false
VITE_OASIS_STORAGE_CONTRACT=0xYOUR_OASIS_STORAGE_CONTRACT
VITE_OASIS_CHAIN=oasis-sapphire-testnet
SAPPHIRE_TESTNET_RPC_URL=https://testnet.sapphire.oasis.io
SIWE_DOMAIN=localhost:5173
# Optional authenticated Sapphire preview endpoint. If omitted, frontend derives `/read`
# from `VITE_OASIS_UPLOAD_API_URL` when that upload service is configured.
VITE_OASIS_READ_API_URL=http://localhost:3000/read

# Auto-reveal relayer runtime settings
AUTO_REVEAL_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY
AUTO_REVEAL_BOUNTY_HUB_ADDRESS=0xYOUR_BOUNTY_HUB_ADDRESS
AUTO_REVEAL_CHAIN_ID=11155111
AUTO_REVEAL_LOOKBACK_BLOCKS=5000
AUTO_REVEAL_REPLAY_OVERLAP_BLOCKS=12
AUTO_REVEAL_LOG_CHUNK_BLOCKS=5000
AUTO_REVEAL_CURSOR_FILE=.auto-reveal-cursor.json
