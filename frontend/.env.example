# Frontend-only Vite env surface
# Copy to frontend/.env for local development, or configure the same keys in Vercel.

VITE_BOUNTY_HUB_ADDRESS=0xYOUR_BOUNTY_HUB_ADDRESS

# Reown / WalletConnect AppKit config for wallet connection.
# VITE_PUBLIC_APP_URL should match your deployed site origin, e.g. https://www.antisoon.com
VITE_REOWN_PROJECT_ID=9bfcfddfcd5c1c5381b624d26565cfcf
VITE_PUBLIC_APP_URL=https://www.antisoon.com

# Provide at least one Sepolia RPC for reliable browser reads.
VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com,https://rpc.sepolia.org,https://ethereum-sepolia.blockpi.network/v1/rpc/public

# Required for encrypted PoC upload unless a relayer API is configured.
VITE_OASIS_STORAGE_CONTRACT=0xYOUR_OASIS_STORAGE_CONTRACT

# Optional relayer-backed Sapphire upload/read flow.
VITE_OASIS_UPLOAD_API_URL=
VITE_OASIS_READ_API_URL=

# Optional backend API base URL for manual workflow triggers such as manual-reveal and manual-jury.
# Leave blank to use the current origin, or point it at your cre-simulator host in split local dev.
VITE_CRE_SIM_API_URL=

# Optional feature/config flags.
VITE_ENABLE_DOCS=true
VITE_PREVIEW_FALLBACK=false
VITE_SUBMISSION_MODE=acl-only-v1
VITE_OASIS_TX_ENCRYPTION=true
VITE_OASIS_CHAIN=oasis-sapphire-testnet
